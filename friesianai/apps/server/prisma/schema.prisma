// FriesianAI database schema (PostgreSQL).
//
// Future-ready notes:
// - Semantic search: enable the pgvector extension and add an `Embedding`
//   model with `vector Unsupported("vector(1536)")`, linked to File chunks,
//   messages, and notes. The `indexed` flag on File anticipates this.
// - Multi-user workspaces: add User + Workspace models and a `workspaceId`
//   on Project; everything below already hangs off Project, so isolation
//   semantics stay unchanged.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectKind {
  PERSONAL
  CODING
  RESEARCH
  BUSINESS
  UNIVERSITY
  SAT
  FITNESS
  GENERAL
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageStatus {
  COMPLETE
  STREAMING
  ERROR
  STOPPED
}

enum FileKind {
  PDF
  TEXT
  MARKDOWN
  IMAGE
  OTHER
}

model Project {
  id           String      @id @default(uuid())
  name         String
  kind         ProjectKind @default(GENERAL)
  color        String      @default("blue")
  description  String      @default("")
  /// Injected as system context for every chat in the project.
  instructions String      @default("")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  conversations Conversation[]
  files         File[]
  notes         Note[]
  pinnedPrompts PinnedPrompt[]

  @@index([updatedAt])
}

model Conversation {
  id        String   @id @default(uuid())
  title     String   @default("New chat")
  /// Model id in "provider/model" form, e.g. "anthropic/claude-sonnet".
  modelId   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([projectId, updatedAt])
}

model Message {
  id        String        @id @default(uuid())
  role      MessageRole
  content   String
  status    MessageStatus @default(COMPLETE)
  /// Model that produced this message (assistant messages).
  modelId   String?
  createdAt DateTime      @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model File {
  id        String   @id @default(uuid())
  name      String
  kind      FileKind @default(OTHER)
  mimeType  String
  size      Int
  /// Storage location (object storage key / local path); metadata-only in MVP.
  storageKey String?
  /// Set once the file has been chunked + embedded for semantic search.
  indexed   Boolean  @default(false)
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, updatedAt])
}

model PinnedPrompt {
  id        String   @id @default(uuid())
  title     String
  prompt    String
  createdAt DateTime @default(now())

  /// Null = available in every project.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
